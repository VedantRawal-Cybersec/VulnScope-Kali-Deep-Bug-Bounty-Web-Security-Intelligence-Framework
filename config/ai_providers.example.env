# VulnScope-Kali AI Analyst Engine
# Copy this file to .env.local or export these variables in your shell.
# Never commit real API keys to GitHub.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Groq
GROQ_API_KEY=
